# Copy this file to .env (in the project root, one level above backend/) and fill in your values.
# Never commit .env to version control.

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-random-secret-key-here

# Comma-separated list of domains Django will serve
ALLOWED_HOSTS=api.middlebeltmemorial.org

# MySQL database (create via cPanel → MySQL Databases)
DB_NAME=cpanelusername_dbname
DB_USER=cpanelusername_dbuser
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=3306

# Comma-separated list of origins allowed to call the API
# Must match the exact scheme + domain of your frontend
CORS_ALLOWED_ORIGINS=https://web.middlebeltmemorial.org

# Comma-separated list of origins trusted for CSRF (usually same as CORS_ALLOWED_ORIGINS)
CSRF_TRUSTED_ORIGINS=https://web.middlebeltmemorial.org,https://api.middlebeltmemorial.org
