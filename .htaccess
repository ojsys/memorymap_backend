# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home/middlebe/memorymap"
PassengerBaseURI "/"
PassengerPython "/home/middlebe/virtualenv/memorymap/3.11/bin/python"
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Exclude /web (React frontend) from Django handling
    RewriteCond %{REQUEST_URI} ^/web
    RewriteRule ^ - [L]
</IfModule>
